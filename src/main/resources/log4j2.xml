<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>

        <!-- ConsoleAppender → prints logs to IntelliJ console -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <!--
                %d  = timestamp
                %t  = thread name
                %-5level = log level padded to 5 chars (INFO , WARN , ERROR)
                %logger{36} = class name (max 36 chars)
                %msg = the actual log message
                %n   = newline
            -->
        </Console>

        <!-- FileAppender → writes logs to a .log file on disk -->
        <File name="FileAppender" fileName="logs/test-execution.log" append="false">
            <!-- append="false" → clears log file on every new run, keeping it fresh -->
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </File>

    </Appenders>

    <Loggers>

        <!-- Suppress WebDriverManager noisy logs -->
        <Logger name="io.github.bonigarcia" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <!-- Suppress Selenium internal logs -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <!-- Your project logs stay at INFO -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>

    </Loggers>

</Configuration>